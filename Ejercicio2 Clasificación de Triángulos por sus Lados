Leer tres longitudes y determinar si forman un triángulo válido y, de ser así, si es equilátero, isósceles o escaleno

public class TrianguloPro {
    public static void main(String[] args) {
        double a = 5, b = 5, c = 8;
        if (a + b > c && a + c > b && b + c > a) {
            if (a == b && b == c) System.out.println("Equilátero");
            else if (a == b || a == c || b == c) System.out.println("Isósceles");
            else System.out.println("Escaleno");
        } else System.out.println("No es un triángulo válido");
    }
}
