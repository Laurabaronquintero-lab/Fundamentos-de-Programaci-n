Realizar la suma de dos matrices de 3×3 e imprimir el resultado.

public class SumaMatrices {
    public static void main(String[] args) {
        int[][] m1 = {{1, 2}, {3, 4}}, m2 = {{5, 6}, {7, 8}};
        int[][] r = new int[2][2];
        for (int i = 0; i < 2; i++) {
            for (int j = 0; j < 2; j++) {
                r[i][j] = m1[i][j] + m2[i][j];
                System.out.print(r[i][j] + " ");
            }
            System.out.println();
        }
    }
}
